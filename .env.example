# Copy this file to .env.local and fill in your actual values.
# .env.local is gitignored — never put real secrets in .env.example.

# Resend transactional email — sign up at resend.com
RESEND_API_KEY=re_xxx_your_key_here

# Where contact + intake submissions get sent
CONTACT_EMAIL_TO=hello@russle.co.uk
CONTACT_EMAIL_FROM=russle <studio@mail.russle.co.uk>

# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Meta (Facebook) Pixel ID, 15-16 digit number from Meta Events Manager
NEXT_PUBLIC_META_PIXEL_ID=

# Cal.com booking embed (e.g. russle/discovery)
NEXT_PUBLIC_CAL_LINK=russle/discovery

# Canonical site URL
NEXT_PUBLIC_SITE_URL=https://russle.co.uk

# Google Places API key (server-side only, do not prefix with NEXT_PUBLIC_).
# Used to pull GBP reviews. Get from Google Cloud Console → APIs & Services →
# Credentials. Restrict to the Places API and your server's IP / referer.
GOOGLE_PLACES_API_KEY=

# Place ID for the russle Google Business Profile. Find via Place ID Finder
# or by searching for russle in Google Maps. Format: ChIJ...
GOOGLE_PLACES_PLACE_ID=