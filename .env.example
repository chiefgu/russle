# Copy this file to .env.local and fill in your actual values.
# .env.local is gitignored — never put real secrets in .env.example.

# Resend transactional email — sign up at resend.com
RESEND_API_KEY=re_xxx_your_key_here

# Where contact + intake submissions get sent
CONTACT_EMAIL_TO=hello@russle.co.uk
CONTACT_EMAIL_FROM=russle <noreply@russle.co.uk>

# Google Analytics 4 measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Cal.com booking embed (e.g. russle/discovery)
NEXT_PUBLIC_CAL_LINK=russle/discovery

# Canonical site URL
NEXT_PUBLIC_SITE_URL=https://russle.co.uk
